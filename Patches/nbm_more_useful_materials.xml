<Patch>

    <!--==========
    [CNEIO] More Useful Materials
    ==========-->

    <!--Remove burning from select materials-->
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>More Useful Materials</li>
        </mods>
        <match Class="PatchOperationSequence">
            <success>Always</success>
            <operations>
                <!--Remove burning from select materials-->
                <li Class="PatchOperationReplace">
                    <xpath>/Defs/ThingDef[defName="MUM_TemperedSteel" or defName="MUM_CarbonFiber" or defName="MUM_AdvancedCeramic" or defName="MUM_HeavyDUComposite"]/stuffProps/statFactors/Flammability</xpath>
                    <value>
                        <Flammability>0</Flammability>
                    </value>
                </li>
            </operations>
        </match>
    </Operation>

</Patch>